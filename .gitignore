# Backend (Maven)
backend/target/
*.class

# Python (execution-engine tracer, run locally against sample scripts)
__pycache__/
*.pyc

# Frontend (Node/Vite)
frontend/node_modules/
frontend/dist/
node_modules/
dist/

# Secrets / local environment overrides - never commit real credentials
.env
.env.*
application-local.yml
application-local.yaml
application-secrets.yml
application-secrets.yaml
*-local.properties

# Local editor/tooling state (personal, machine-specific - not app source)
.claude/

# Internal working notes - kept locally, never committed (repo is public).
# READMEs are intentionally NOT ignored (they're the public-facing docs).
CLAUDE.md
implementation-notes.md
CHECKLIST.md
memory.md

# IDE
.idea/
*.iml

# OS
.DS_Store
Thumbs.db
